{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "tests",
    "pages",
    "fixtures",
    "playwright.config.ts"
  ]
}
